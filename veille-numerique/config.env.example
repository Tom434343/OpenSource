# VeilleNumerique — Variables d'environnement
# Copiez ce fichier vers config.env et remplissez vos valeurs :
#   cp config.env.example config.env

# ─── Claude API (obligatoire) ───────────────────────────────────────────────
# Obtenez votre cle sur https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-VOTRE_CLE_ICI"

# ─── Email (obligatoire pour recevoir les rapports) ─────────────────────────
VEILLE_EMAIL_TO="vous@example.com"
VEILLE_EMAIL_FROM="veille@example.com"

# ─── SMTP ────────────────────────────────────────────────────────────────────
# Exemples :
#   Gmail      : smtp.gmail.com / 587 / votre@gmail.com / mot-de-passe-application
#   ProtonMail : 127.0.0.1 / 1025 (via ProtonMail Bridge local)
#   Mailgun    : smtp.mailgun.org / 587
VEILLE_SMTP_HOST="127.0.0.1"
VEILLE_SMTP_PORT="587"
VEILLE_SMTP_USER=""
VEILLE_SMTP_PASS=""

# ─── Optionnel ───────────────────────────────────────────────────────────────
# Nombre de jours en arriere pour chercher les articles (defaut: 1)
VEILLE_DAYS_BACK="1"
